{
  "manifest_version": 3,
  "name": "Job Helper",
  "description": "React and Vite starter for capturing page data from the active Chrome tab.",
  "version": "0.1.0",
  "action": {
    "default_popup": "index.html",
    "default_title": "Job Helper"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
