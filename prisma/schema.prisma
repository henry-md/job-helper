generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  accounts                Account[]
  applications            JobApplication[]
  companies               Company[]
  people                  Person[]
  sessions                Session[]
  screenshots             JobApplicationScreenshot[]
  tailorResumeLockedLinks TailorResumeLockedLink[]
}

model TailorResumeLockedLink {
  id        String   @id @default(cuid())
  userId    String
  key       String
  label     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, updatedAt(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum ExtractionStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

model Company {
  id             String           @id @default(cuid())
  userId         String
  name           String
  normalizedName String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   JobApplication[]
  people         Person[]
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, createdAt(sort: Desc)])
}

model Person {
  id                   String           @id @default(cuid())
  userId               String
  companyId            String?
  name                 String
  normalizedName       String
  email                String?
  phoneNumber          String?
  notes                String?
  recruiterContact     String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  company              Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  referredApplications JobApplication[] @relation("JobApplicationReferrer")
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, createdAt(sort: Desc)])
  @@index([companyId])
}

model JobApplicationScreenshot {
  id               String           @id @default(cuid())
  userId           String
  applicationId    String?
  originalFilename String
  storagePath      String
  mimeType         String
  sizeBytes        Int
  extractionStatus ExtractionStatus @default(PENDING)
  extractionModel  String?
  extractionError  String?
  extractedPayload Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  application      JobApplication?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([extractionStatus])
}

model JobApplication {
  id               String                   @id @default(cuid())
  userId           String
  companyId        String
  referrerId       String?
  title            String
  status           ApplicationStatus       @default(APPLIED)
  location         String?
  onsiteDaysPerWeek Int?
  jobUrl           String?
  salaryRange      String?
  salaryMinimum    Int?
  salaryMaximum    Int?
  employmentType   String?
  teamOrDepartment String?
  recruiterContact String?
  notes            String?
  hasReferral      Boolean                  @default(false)
  jobDescription   String?
  appliedAt        DateTime
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referrer         Person?                  @relation("JobApplicationReferrer", fields: [referrerId], references: [id], onDelete: SetNull)
  screenshots      JobApplicationScreenshot[]
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([status])
  @@index([referrerId])
}
