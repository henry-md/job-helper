generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  accounts                Account[]
  applications            JobApplication[]
  companies               Company[]
  syncState               UserSyncState?
  people                  Person[]
  sessions                Session[]
  screenshots             JobApplicationScreenshot[]
  tailorResumeLockedLinks TailorResumeLockedLink[]
  tailorResumeUserMemory  TailorResumeUserMemory?
  tailorResumeKeywordClassifications TailorResumeKeywordClassification[]
  tailorResumeSkills      TailorResumeSkill[]
  tailorResumeSpareBullets TailorResumeSpareBullet[]
  tailorResumeChatThreads TailorResumeChatThread[]
  tailorResumeChatMessages TailorResumeChatMessage[]
  tailorResumeRuns        TailorResumeRun[]
  tailoredResumes         TailoredResume[]
  aiUsageEvents           AiUsageEvent[]
  latexBuildFailures      LatexBuildFailure[]
}

model LatexBuildFailure {
  id        String   @id @default(cuid())
  userId    String
  source    String
  latexCode String
  error     String
  attempt   Int      @default(1)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model TailorResumeLockedLink {
  id        String   @id @default(cuid())
  userId    String
  key       String
  label     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, updatedAt(sort: Desc)])
}

model TailorResumeUserMemory {
  id              String   @id @default(cuid())
  userId          String   @unique
  markdown        String
  nonTechnologies String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt(sort: Desc)])
}

enum TailorResumeKeywordKind {
  SKILLS_SECTION @map("HARD")
  NARRATIVE      @map("SOFT")
  NON_SKILL
}

enum TailorResumeKeywordPriority {
  HIGH
  LOW
}

model TailorResumeKeywordClassification {
  id             String                  @id @default(cuid())
  userId         String
  name           String
  normalizedName String
  kind           TailorResumeKeywordKind
  priority       TailorResumeKeywordPriority?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, kind, updatedAt(sort: Desc)])
}

model TailorResumeSkill {
  id               String                    @id @default(cuid())
  userId           String
  name             String
  normalizedName   String
  listInSkillsOnly Boolean                   @default(false)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  spareBullets     TailorResumeSpareBulletSkill[]
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, updatedAt(sort: Desc)])
}

model TailorResumeSpareBullet {
  id                 String                    @id @default(cuid())
  userId             String
  quote              String                    @db.Text
  replacesQuote      String?                   @db.Text
  resumeExperienceId String
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  skills             TailorResumeSpareBulletSkill[]
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resumeExperienceId, updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
}

model TailorResumeSpareBulletSkill {
  spareBulletId String
  skillId       String
  createdAt     DateTime                @default(now())
  skill         TailorResumeSkill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  spareBullet   TailorResumeSpareBullet @relation(fields: [spareBulletId], references: [id], onDelete: Cascade)

  @@id([spareBulletId, skillId])
  @@index([skillId])
}

enum TailorResumeChatRole {
  USER
  ASSISTANT
}

model TailorResumeChatThread {
  id        String                    @id @default(cuid())
  userId    String
  url       String                    @db.Text
  urlHash   String
  pageTitle String?
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  messages  TailorResumeChatMessage[]
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, urlHash])
  @@index([userId, updatedAt(sort: Desc)])
}

model TailorResumeChatMessage {
  id        String                @id @default(cuid())
  userId    String
  threadId  String
  role      TailorResumeChatRole
  content   String                @db.Text
  model     String?
  toolCalls Json                  @default("[]")
  createdAt DateTime              @default(now())
  thread    TailorResumeChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([userId, createdAt(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum ExtractionStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum TailorResumeRunStatus {
  RUNNING
  NEEDS_INPUT
  SUCCEEDED
  FAILED
  CANCELLED
}

enum AiUsageProvider {
  OPENAI
  ANTHROPIC
}

enum AiUsageStatus {
  SUCCEEDED
  FAILED
}

enum AiUsageSubjectStatus {
  UNARCHIVED
  ARCHIVED
  DELETED
}

model Company {
  id             String           @id @default(cuid())
  userId         String
  name           String
  normalizedName String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   JobApplication[]
  people         Person[]
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, createdAt(sort: Desc)])
}

model Person {
  id                   String           @id @default(cuid())
  userId               String
  companyId            String?
  name                 String
  normalizedName       String
  email                String?
  phoneNumber          String?
  notes                String?
  recruiterContact     String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  company              Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  referredApplications JobApplication[] @relation("JobApplicationReferrer")
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, createdAt(sort: Desc)])
  @@index([companyId])
}

model JobApplicationScreenshot {
  id               String           @id @default(cuid())
  userId           String
  applicationId    String?
  originalFilename String
  storagePath      String
  mimeType         String
  sizeBytes        Int
  extractionStatus ExtractionStatus @default(PENDING)
  extractionModel  String?
  extractionError  String?
  extractedPayload Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  application      JobApplication?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([extractionStatus])
}

model JobApplication {
  id               String                   @id @default(cuid())
  userId           String
  companyId        String
  referrerId       String?
  title            String
  status           ApplicationStatus       @default(APPLIED)
  location         String?
  onsiteDaysPerWeek Int?
  jobUrl           String?
  salaryRange      String?
  salaryMinimum    Int?
  salaryMaximum    Int?
  employmentType   String?
  teamOrDepartment String?
  recruiterContact String?
  notes            String?
  hasReferral      Boolean                  @default(false)
  starred          Boolean                  @default(false)
  jobDescription   String?
  jobUrlHash       String?
  archivedAt       DateTime?
  appliedAt        DateTime
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referrer         Person?                  @relation("JobApplicationReferrer", fields: [referrerId], references: [id], onDelete: SetNull)
  screenshots      JobApplicationScreenshot[]
  tailorResumeRuns TailorResumeRun[]
  tailoredResumes  TailoredResume[]
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobUrlHash])
  @@index([userId, archivedAt])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([status])
  @@index([referrerId])
}

model TailorResumeRun {
  id               String                @id @default(cuid())
  userId           String
  applicationId    String
  tailoredResumeId String?
  status           TailorResumeRunStatus @default(RUNNING)
  jobUrl           String?
  jobUrlHash       String?
  jobDescription   String                @db.Text
  stepNumber       Int?
  stepCount        Int?
  stepStatus       String?
  stepSummary      String?
  stepDetail       String?               @db.Text
  stepAttempt      Int?
  stepRetrying     Boolean               @default(false)
  generationStepTimings Json             @default("[]")
  error            String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  application      JobApplication        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tailoredResume   TailoredResume?       @relation(fields: [tailoredResumeId], references: [id], onDelete: SetNull)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId, updatedAt(sort: Desc)])
  @@index([userId, status, updatedAt(sort: Desc)])
  @@index([userId, jobUrlHash, updatedAt(sort: Desc)])
}

model TailoredResume {
  id              String           @id @default(cuid())
  userId          String
  applicationId   String?
  profileRecordId String
  jobUrl          String?
  jobUrlHash      String?
  displayName     String
  companyName     String?
  positionTitle   String?
  status          String
  error           String?          @db.Text
  generationStepTimings Json       @default("[]")
  starred         Boolean          @default(false)
  archivedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  application     JobApplication?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  runs            TailorResumeRun[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, profileRecordId])
  @@index([applicationId, updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, jobUrlHash, updatedAt(sort: Desc)])
}

model AiUsageEvent {
  id                         String               @id @default(cuid())
  userId                     String
  applicationId              String?
  tailorResumeRunId          String?
  tailoredResumeId           String?
  jobUrl                     String?              @db.Text
  jobUrlHash                 String?
  subjectStatus              AiUsageSubjectStatus @default(UNARCHIVED)
  provider                   AiUsageProvider
  model                      String
  operation                  String
  stepNumber                 Int?
  stepLabel                  String?
  attempt                    Int?
  round                      Int?
  requestStartedAt           DateTime
  requestFinishedAt          DateTime?
  durationMs                 Int?
  status                     AiUsageStatus
  error                      String?              @db.Text
  providerResponseId         String?
  inputTokens                Int                  @default(0)
  cachedInputTokens          Int                  @default(0)
  cacheCreationInputTokens   Int                  @default(0)
  outputTokens               Int                  @default(0)
  reasoningTokens            Int                  @default(0)
  totalTokens                Int                  @default(0)
  inputCostUsdMicros         BigInt               @default(0)
  cachedInputCostUsdMicros   BigInt               @default(0)
  cacheCreationCostUsdMicros BigInt               @default(0)
  outputCostUsdMicros        BigInt               @default(0)
  totalCostUsdMicros         BigInt               @default(0)
  pricingSnapshot            Json                 @default("{}")
  rawUsage                   Json                 @default("{}")
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  user                       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, requestStartedAt(sort: Desc)])
  @@index([userId, subjectStatus, requestStartedAt(sort: Desc)])
  @@index([userId, jobUrlHash, requestStartedAt(sort: Desc)])
  @@index([tailorResumeRunId, requestStartedAt(sort: Desc)])
  @@index([tailoredResumeId, requestStartedAt(sort: Desc)])
}

model UserSyncState {
  id                  String   @id @default(cuid())
  userId              String   @unique
  applicationsVersion Int      @default(0)
  tailoringVersion    Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt(sort: Desc)])
}
