# Google OAuth
NEXTAUTH_URL="http://localhost:1285"
NEXTAUTH_SECRET="replace-with-a-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Chrome Extension OAuth
GOOGLE_EXTENSION_CLIENT_ID="replace-with-google-chrome-extension-client-id"
VITE_JOB_HELPER_APP_BASE_URL="http://localhost:1285"
CHROME_EXTENSION_PUBLIC_KEY="" # optional: keeps the unpacked extension id stable

# PosgreSQL
DATABASE_URL="postgresql://username:password@host:port/database"

# OpenAI
OPENAI_API_KEY="replace-with-openai-api-key"
OPENAI_JOB_EXTRACTION_MODEL="gpt-5-mini" # Scrapes page and collects structured data (company name, job title, job description, etc.)
OPENAI_RESUME_EXTRACTION_MODEL="gpt-5-mini" # Converts pdf resume to LaTeX
OPENAI_TAILOR_RESUME_KEYWORD_MODEL="gpt-5.4-mini" # step 1 — extraction and classification
OPENAI_TAILOR_RESUME_MODEL="gpt-5.5" # step 4 — block edits
OPENAI_TAILOR_RESUME_COMPACTION_MODEL="gpt-5.4" # step 4b — page-count compaction
TAILOR_RESUME_PLANNING_MODEL="anthropic:claude-sonnet-4-6" # step 3 — edit intent planning
OPENAI_MASTER_CHAT_MODEL="gpt-5.4" # 'master chat' in lower right corner of extension
RETRY_ATTEMPTS_TO_GENERATE_LATEX_FROM_PDF="3"
RETRY_ATTEMPTS_TO_GENERATE_LATEX_EDITS="3"
RETRY_ATTEMPTS_TO_GENERATE_PAGE_COUNT_COMPACTION="5"
TEST_OPENAI_RESPONSE="false"
USE_DENY_LIST_FOR_KEYWORDS="false"

# Anthropic
ANTHROPIC_API_KEY="replace-with-anthropic-api-key"

# Debugging
DEBUG_UI="false" # enables debug-only UI controls without adding a separate tab
DEBUG_FORCE_CONVERSATION_IN_TAILOR_PIPELINE="false" # force llm to actually ask a clarifying question in step 2 of resume-tailoring.
TYPING_SPEED_ANIMTION="180"
TYPING_SPEED_ANIMATION_WORD_PAUSE_MS="20" # additional pause above character-spacing
TYPING_SPEED_ANIMATION_SENTENCE_PAUSE_MS="250" # additional pause between sentences
